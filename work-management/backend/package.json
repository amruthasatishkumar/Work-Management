{
  "name": "work-management-backend",
  "version": "1.0.0",
  "description": "Backend API for Work Management app",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js && node -e \"require('fs').copyFileSync('node_modules/node-sqlite3-wasm/dist/node-sqlite3-wasm.wasm', 'dist/node-sqlite3-wasm.wasm')\"",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "node-sqlite3-wasm": "^0.8.55",
    "openai": "^6.32.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
